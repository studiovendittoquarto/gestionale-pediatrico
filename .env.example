# ====== CONFIGURAZIONE GESTIONALE PEDIATRICO ======
# Copia questo file in ".env" per lo sviluppo locale.
# In produzione (Render) imposta queste variabili nella dashboard.

# Stringa di connessione del database PostgreSQL (es. da Neon.tech)
DATABASE_URL=postgresql://utente:password@host/dbname?sslmode=require

# Credenziali UNICHE condivise da tutti i pediatri per accedere
APP_USERNAME=pediatra
APP_PASSWORD=cambiami-subito

# Chiave segreta per firmare i token di login (metti una stringa lunga a caso)
JWT_SECRET=metti-qui-una-stringa-lunga-e-casuale

# Porta (Render la imposta da solo, in locale usa 3000)
PORT=3000
